@startuml
title Activity Diagram - Iterazione 3

|Browser|
start
:Applicazione React;

|API Gateway|
:Riceve GET\n(con httpOnly cookie);

if (Cookie presente e JWT valido?) then (Sì)
  :Recupera profilo da MongoDB;

  |Browser|
  :Carica conversazione salvata;
else (No)
  |Browser|
  :Pagina Login;

  if (Azione utente?) then (Login)
    |API Gateway|
    :POST verifica credenziali;
    :Genera JWT e imposta\nhttpOnly cookie;
    :Restituisce profilo;

    |Browser|
    :Salva profilo in memoria;
    :Carica conversazione (se presente);
  else (Registrazione)
    |API Gateway|
    :POST crea account;
    :Genera JWT e imposta\nhttpOnly cookie;
    :Restituisce profilo;

    |Browser|
    :Salva profilo in memoria;
  endif
endif

|Browser|
:Mostra interfaccia chat;
:Utente inserisce domanda;
:Costruisce conversation_history\n(ultimi 10 messaggi);

|API Gateway|
:Riceve POST \n(cookie + query + history);

|Orchestrator Agent|
:Inizializza AgentState\n(profilo + query + history);

|Classifier Agent|
:Classifica intento;
:Restituisce categoria;

|Orchestrator Agent|
:Invia query + profilo + history\nal Generator;

|Generator Agent|
:Genera risposta contestualizzata;
:Restituisce bozza;

|Orchestrator Agent|
:Invia bozza + history\nal Revision;

|Revision Agent|
:Revisiona risposta;
:Restituisce risposta finale;

|Orchestrator Agent|
:Restituisce risposta all'API;

|API Gateway|
:Invia risposta al browser;

|Browser|
:Aggiunge messaggio alla conversazione;
:Salva conversazione;

if (Logout?) then (Sì)
  |API Gateway|
  :POST Elimina httpOnly cookie;

  |Browser|
  :Cancella profilo dalla memoria;
  :Cancella conversazione;
else (No)
  |Browser|
  :Attende prossima domanda;
endif

stop

@enduml