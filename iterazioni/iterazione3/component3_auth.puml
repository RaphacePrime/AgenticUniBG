@startuml
skinparam componentStyle uml2
top to bottom direction
skinparam nodesep 70
skinparam ranksep 50

title Component Diagram - Iterazione 3 (Authentication Layer)

component "Authentication Layer" {

    portin  pAuthIn
    portout pDataOut

    component [Auth Controller] <<component>> as AuthCtrl
    component [Auth Service]    <<component>> as AuthSvc
    component [JWT Manager]     <<component>> as JWT

    interface "IAuthAPI"     as IAuthAPI
    interface "IAuthService" as IAuthSvc
    interface "IJWTManager"  as IJWT

    ' ─── Ingresso dal Gateway ─────────────────────────────────
    pAuthIn --> IAuthAPI
    IAuthAPI  -  AuthCtrl

    ' ─── Controller → Service ─────────────────────────────────
    AuthCtrl --( IAuthSvc
    IAuthSvc  -  AuthSvc

    ' ─── Service → JWT Manager ────────────────────────────────
    AuthSvc --( IJWT
    IJWT     -  JWT

    ' ─── Service → Data Tier ──────────────────────────────────
    AuthSvc --> pDataOut
}

note right of AuthCtrl
  _set_auth_cookie() imposta
  JWT come httpOnly cookie
  (secure, samesite=none)
end note

note right of JWT
  validateFromRequest()
  estrae token dal cookie
  httpOnly della richiesta
end note

@enduml
