@startuml
title Memoria Conversazionale - Opzione Redis (Sequence)

actor       Studente        as S
participant "Frontend"            as FE
participant "POST /api/agent/query" as API
participant "OrchestratorAgent"              as ORC
participant "ConversationRepository\n(Redis)" as REPO
database    "Redis\nchat:{matricola}"        as RDS
database    "MongoDB\nconversations"         as MDB

' ─── Login ────────────────────────────────────────────────────
S -> FE : login
FE -> API : POST /api/auth/login
API --> FE : JWT cookie + userInfo

' ─── Turno N ──────────────────────────────────────────────────
S -> FE : invia messaggio

FE -> API : POST /api/agent/query\n{ query, user_info }\n(niente conversation_history)

API -> ORC : process_query(query, user_info, conv_repo)

ORC -> REPO : getHistory(matricola)
REPO -> RDS : LRANGE chat:{matricola} 0 19
RDS --> REPO : ultimi 20 msg (10 scambi)
REPO --> ORC : conversation_history[]

ORC -> ORC : crea AgentState\n{ query, conversation_history, user_info, ... }
ORC -> ORC : Classifier → Generator → Revisor\n(invariati, leggono da AgentState)
ORC -> ORC : final_response pronto

ORC -> REPO : appendMessages(matricola, user_msg, assistant_msg)
REPO -> RDS : RPUSH chat:{matricola} user_msg
REPO -> RDS : RPUSH chat:{matricola} assistant_msg
REPO -> RDS : LTRIM chat:{matricola} 0 19\n(max 20 msg)
REPO -> RDS : EXPIRE chat:{matricola} 86400\n(TTL reset a 24h)

ORC --> API : { response, metadata }
API --> FE : { response, metadata }
FE --> S : mostra risposta

' ─── Logout / flush su MongoDB ────────────────────────────────
S -> FE : logout
FE -> API : POST /api/auth/logout

API -> REPO : flushToMongoDB(matricola)
REPO -> RDS : LRANGE chat:{matricola} 0 -1\n(legge tutta la history)
RDS --> REPO : tutti i messaggi
REPO -> MDB : insert conversation\n{ matricola, messages[], closedAt }
REPO -> RDS : DEL chat:{matricola}

API --> FE : cookie eliminato
FE --> S : redirect login

@enduml