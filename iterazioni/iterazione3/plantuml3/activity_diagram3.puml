@startuml
title Activity Diagram - Iterazione 3

|Browser|
start
:Applicazione React;

|API Gateway|
:Riceve GET\n(con httpOnly cookie);

if (Cookie presente e JWT valido?) then (Sì)
  |MongoDB|
  :Cerca profilo utente;
  :Restituisce profilo;

  |API Gateway|
  :Invia profilo al browser;

  |Browser|
  :Carica conversazione salvata;
else (No)
  |Browser|
  :Pagina Login;

  if (Azione utente?) then (Login)
    |API Gateway|
    :POST /login\nriceve credenziali;

    |MongoDB|
    :Cerca utente;
    :Verifica password hash;
    :Restituisce dati utente;

    |API Gateway|
    :Genera JWT e imposta\nhttpOnly cookie;
    :Restituisce profilo;

    |Browser|
    :Salva profilo in memoria;
    :Carica conversazione (se presente);
  else (Registrazione)
    |API Gateway|
    :POST /register\nriceve dati nuovo utente;

    |MongoDB|
    :Crea nuovo utente;
    :Restituisce utente creato;

    |API Gateway|
    :Genera JWT e imposta\nhttpOnly cookie;
    :Restituisce profilo;

    |Browser|
    :Salva profilo in memoria;
  endif
endif

|Browser|
:Utente inserisce domanda;
:Costruisce conversation_history\n(ultimi 10 messaggi);

|API Gateway|
:Riceve POST\n(cookie + query + history);
:Valida JWT;

|MongoDB|
:Recupera profilo aggiornato\ndell'utente;
:Restituisce profilo;

|API Gateway|
:Inoltra query + profilo + history;

|Orchestrator Agent|
:Inizializza AgentState;

|Classifier Agent|
:Classifica intento;
:Restituisce categoria;

|Orchestrator Agent|
:Invia query + profilo + history;

|Generator Agent|
:Genera risposta contestualizzata;
:Restituisce bozza;

|Orchestrator Agent|
:Invia bozza + history;

|Revision Agent|
:Revisiona risposta;
:Restituisce risposta finale;

|Orchestrator Agent|
:Restituisce risposta;

|API Gateway|
:Invia risposta al browser;

|Browser|
:Aggiunge messaggio alla conversazione;
:Salva conversazione;

if (Logout?) then (Sì)
  |API Gateway|
  :POST /logout\nElimina httpOnly cookie;

  |Browser|
  :Cancella profilo dalla memoria;
  :Cancella conversazione;
else (No)
  |Browser|
  :Attende prossima domanda;
endif

stop

@enduml