@startuml
skinparam componentStyle uml2
left to right direction
skinparam nodesep 80
skinparam ranksep 60
skinparam padding 10

title Component Diagram - Iterazione 3\nAlternativa B: Memoria con Redis

' ─── Client Tier ─────────────────────────────────────────────
component "Client Tier" as ClientTier {
    portout pHttpOut
    component [Web App\n(React + Vite)] <<component>> as Client
    Client --> pHttpOut
}

' ─── Interfaccia Client ↔ Backend ────────────────────────────
interface "HTTP/REST\nhttpOnly Cookie" as IHTTP

' ─── Backend Tier ────────────────────────────────────────────
component "Backend Tier" as BackendTier {
    portin  pHttpIn
    portout pDataOut

    interface "IAuthAPI"      as IAuthAPI
    interface "IOrchestrator" as IOrch

    component [API Gateway\n(FastAPI)]           <<component>> as Gateway
    component [Authentication Layer]             <<component>> as AuthLayer
    component [Agent Layer]                      <<component>> as AgentLayer
    component [Conversation Repository\n(Redis)] <<component>> as ConvRepo

    pHttpIn --> Gateway

    Gateway --( IAuthAPI
    IAuthAPI  -  AuthLayer

    Gateway --( IOrch
    IOrch    -  AgentLayer

    AgentLayer --> ConvRepo : getHistory / appendMessages

    AuthLayer --> pDataOut
    ConvRepo  --> pDataOut
}

' ─── Interfacce Backend ↔ Data ───────────────────────────────
interface "IProfileRepo" as IProfile
interface "IRedis"       as IRedis

' ─── Data Tier ───────────────────────────────────────────────
component "Data Tier" as DataTier {
    portin pDataIn

    interface "IMongoDriver" as IMongo

    component [Profile Repository] <<component>> as ProfileRepo
    component [MongoDB Atlas]      <<component>> as DB
    component [Redis]              <<component>> as Redis

    pDataIn --> ProfileRepo
    pDataIn --> Redis

    ProfileRepo --( IMongo
    IMongo       -  DB
}

' ─── Connessioni cross-tier ──────────────────────────────────
pHttpOut --> IHTTP
IHTTP    --> pHttpIn

pDataOut --> IProfile
pDataOut --> IRedis
IProfile --> pDataIn
IRedis   --> pDataIn

@enduml
