@startuml
title Architettura a Componenti - Opzione Redis

skinparam componentStyle rectangle

package "Browser" {
  component [App.jsx\n(React)] as FE
  database  "localStorage\n(UI only)" as LS
  note right of LS : usato solo per\nvisualizzazione,\nnon più come\nfonte della history
}

package "Docker - server" {
  component [main.py\n(FastAPI)] as API

  package "auth/" {
    component [JWTManager]        as JWT
    component [AuthController]    as AC
    component [AuthService]       as AS
    component [ProfileRepository] as PR
  }

  package "conversations/" {
    component [ConversationRepository] as CR
    note right of CR
      getHistory(matricola)
      appendMessages(matricola, ...)
      flushToMongoDB(matricola)
    end note
  }

  package "agents/" {
    component [OrchestratorAgent]  as ORC
    component [ClassifierAgent]    as CLA
    component [GeneratorAgent]     as GEN
    component [RevisionAgent]      as REV
    component [AgentState\n(TypedDict)] as AS2
  }
}

package "Docker - redis" {
  database "Redis\nchat:{matricola}\nTTL: 24h" as RDS
}

package "Docker - mongodb" {
  database "MongoDB\nusers\nconversations" as MDB
}

cloud "Groq API\nllama-3.3-70b" as GROQ

' ─── Flussi ──────────────────────────────────────────────────
FE      --> API  : POST /api/agent/query\n{ query, user_info }
FE      --> API  : POST /api/auth/*
FE      <-> LS   : salva UI state

API     --> AC   : login / register
AC      --> AS   : authenticate / createUser
AS      --> JWT  : generateToken / validateToken
AS      --> PR   : findById / save

API     --> ORC  : process_query(query, user_info, conv_repo)
ORC     --> CR   : getHistory(matricola)
CR      <--> RDS : LRANGE / RPUSH / LTRIM / EXPIRE

ORC     --> AS2  : crea / aggiorna stato
ORC     --> CLA  : classify(state)
ORC     --> GEN  : generate(state)
ORC     --> REV  : revise(state)

CLA     --> GROQ : ainvoke
GEN     --> GROQ : ainvoke
REV     --> GROQ : ainvoke

ORC     --> CR   : appendMessages(matricola, ...)
CR      --> RDS  : RPUSH + LTRIM + EXPIRE

PR      <--> MDB : users collection
CR      --> MDB  : flushToMongoDB (al logout)

@enduml
