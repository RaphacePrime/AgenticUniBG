@startuml
title Class Diagram - Iterazione 4 (Frontend Package)

package "frontend" <<folder>> {

    class ConversationStore <<boundary>> {
        -storageKey: String
        +load(matricola: String): List<Message>
        +save(matricola: String, history: List<Message>): void
        +clear(matricola: String): void
    }

    class Message {
        +type: String
        +content: String
        +timestamp: Date
        +category: String
        +metadata: dict
    }
}

' ─── Relazioni ────────────────────────────────────────────────
ConversationStore "1" o--> "*" Message : memorizza

note right of ConversationStore
  Invariato dall'Iterazione 3.
  localStorage del browser con
  key "conversation_{matricola}".
end note

note bottom of Message
  type ∈ {"user", "agent", "error"}
  conversation_history: max 10 msg
  (ultimi 5 scambi) inviati al backend.
end note

@enduml
