@startuml
title Component Diagram - Iteration 4

skinparam componentStyle uml2

' ─── Interfacce fornite (ball) ────────────────────────────────
() "HTTP/REST"          as IHTTP
() "httpOnly Cookie"    as ICookie
() "IAuthAPI"           as IAuthAPI
() "IAuthService"       as IAuthSvc
() "IJWTManager"        as IJWT
() "IProfileRepo"       as IProfile
() "IOrchestrator"      as IOrch
() "IClassifier"        as IClassif
() "IQueryAgent"        as IQuery
() "IWebAgent"          as IWeb
() "IGenerator"         as IGen
() "IRevision"          as IRev
() "IPipelineLogger"    as ILog
() "IMongoDriver"       as IMongo
() "ILocalStorage"      as ILS
() "ITavilyAPI"         as ITavily

' ─── Client Tier ─────────────────────────────────────────────
package "Client Tier" {
  [Web App\n(React + Vite)]          as Client
  [Conversation Store\n(localStorage)] as LS
}

' ─── Backend Tier ────────────────────────────────────────────
package "Backend Tier" {

  [API Gateway\n(FastAPI)] as Gateway

  package "Authentication Layer" {
    [Auth Controller]    as AuthCtrl
    [Auth Service]       as AuthSvc
    [JWT Manager]        as JWT
    [Profile Repository] as ProfileRepo
  }

  package "Agent Layer" {
    [Orchestrator Agent]  as Orch
    [Classifier Agent]    as Classifier
    [Query Agent]         as QueryAg
    [Web Agent]           as WebAg
    [Generator Agent]     as Generator
    [Revision Agent]      as Revision
  }

  package "Logging Layer" {
    [Pipeline Logger]    as Logger
  }
}

' ─── Data Tier ───────────────────────────────────────────────
package "Data Tier" {
  [MongoDB Atlas]         as DB
  [File System\n(logs/)]  as FS
}

' ─── External Services ────────────────────────────────────────
cloud "Tavily Search API" as Tavily
cloud "Google Gemini\n(gemini-2.5-flash)" as Gemini

' ─── Provided interfaces ──────────────────────────────────────
Client      - IHTTP
Client      - ICookie
Gateway     - IAuthAPI
AuthCtrl    - IAuthSvc
AuthSvc     - IJWT
JWT         - IJWT
ProfileRepo - IProfile
Orch        - IOrch
Classifier  - IClassif
QueryAg     - IQuery
WebAg       - IWeb
Generator   - IGen
Revision    - IRev
Logger      - ILog
DB          - IMongo
LS          - ILS
Tavily      - ITavily

' ─── Required interfaces ──────────────────────────────────────
Client       ..> IHTTP    : richieste REST
Client       ..> ICookie  : invia cookie con ogni request
Client       ..> ILS      : persiste conversazione per matricola
Gateway      ..> IAuthAPI : login / register / verify / logout
Gateway      ..> IOrch    : query + conversation_history
AuthCtrl     ..> IAuthSvc : delega logica di business
AuthSvc      ..> IJWT     : genera e valida JWT
AuthSvc      ..> IProfile : recupera / salva profilo
ProfileRepo  ..> IMongo   : persistenza
Orch         ..> IClassif : classifica intento
Orch         ..> IQuery   : genera search query
Orch         ..> IWeb     : esegue ricerca web
Orch         ..> IGen     : genera risposta con web context
Orch         ..> IRev     : revisiona risposta
Orch         ..> ILog     : scrive log pipeline
Logger       ..> FS       : scrive file log txt
WebAg        ..> ITavily  : ricerca su unibg.it

note right of Gemini
  LLM Provider per tutti gli agenti
  (Classifier, QueryAgent,
  Generator, RevisionAgent)
end note

Classifier   ..> Gemini : ainvoke
QueryAg      ..> Gemini : ainvoke
Generator    ..> Gemini : ainvoke
Revision     ..> Gemini : ainvoke

@enduml
