@startuml
skinparam componentStyle uml2

title Component Diagram - Iterazione 1

package "Client Tier" {
    component [Client] <<component>> as Client
}

package "Application Logic Tier" {
    interface "HTTP" as IHTTP
    interface "BusinessLogic" as IBL
    
    component [Web Server] <<component>> as WS
    component [App Server] <<component>> as AS
}

' Relazioni e Interfacce
Client --( IHTTP
IHTTP - WS

WS --( IBL
IBL - AS
note right of IHTTP : Provided by Web Server
note right of IBL : Logic & Services

@enduml