@startuml
frame "Client" as CL {
 [web-app/react] as react
}

frame "Backend" as BA{ 
 
 [API gateway] as API 
 API --down( IOrchestrator
 component Agent {
  [Orchestrator] as OR
  [Classifier] as C
  [Generator] as G
  [Revisioner] as R
  [AgentState] as AS
  
  OR -left- AS
  OR --( classify
  OR --( generate
  OR --( revision
  C -up- classify
  G -up- generate
  R -up- revision

  port p1
 }
 OR ..> p1 : delegate
 IOrchestrator -- p1
 API --right( IAuthController
 component Auth {
  [Controller] AS AC
  [ProfileRepo] AS PR
  [Service] AS SR

  port p2
  port p3
 SR -- IService
 AC --( IService
 PR -- IProfile
 SR --( IProfile
 }

 AC ..> p2 : delegate
 PR ..> p3 : delegate
 IAuthController -- p2
 component Models{
  [User] 
 }
 port p4
 portout p5
 API .up.> p4 : delegate
 API ..> Models : use
 p3 ..> p5 : delegate
}

frame "Data Tier" as DB {
 [MongoDB] as Mdb
}


 
interface "HTTP/REST" as HTTP
react --(HTTP
p4 -up- HTTP
Mdb -down- IMongoDB
p5-right-( IMongoDB
@enduml