@startuml
skinparam componentStyle uml2
left to right direction
skinparam nodesep 80
skinparam ranksep 60
skinparam padding 10

title Component Diagram - Iterazione 2 (Overview)

' ─── Client Tier ─────────────────────────────────────────────
component "Client Tier" as ClientTier {
    portout pHttpOut
    component [Web App] <<component>> as Client
    Client --> pHttpOut
}

' ─── Interfaccia Client ↔ Backend ────────────────────────────
interface "HTTP/REST" as IHTTP

' ─── Backend Tier ────────────────────────────────────────────
component "Backend Tier" as BackendTier {
    portin  pHttpIn
    portout pDataOut1
    portout pDataOut2

    interface "IAuthAPI"      as IAuthAPI
    interface "IOrchestrator" as IOrch

    component [API Gateway]           <<component>> as Gateway
    component [Authentication Layer]  <<component>> as AuthLayer
    component [Agent Layer]           <<component>> as AgentLayer

    pHttpIn --> Gateway

    Gateway --( IAuthAPI
    IAuthAPI  -  AuthLayer

    Gateway --( IOrch
    IOrch    -  AgentLayer

    AuthLayer  --> pDataOut1
    AgentLayer --> pDataOut2
}

' ─── Interfaccia Backend ↔ Data ──────────────────────────────
interface "IProfileRepo" as IProfile

' ─── Data Tier ───────────────────────────────────────────────
component "Data Tier" as DataTier {
    portin pDataIn

    interface "IMongoDriver" as IMongo

    component [Profile Repository] <<component>> as ProfileRepo
    component [MongoDB]            <<component>> as DB

    pDataIn --> ProfileRepo
    ProfileRepo --( IMongo
    IMongo       -  DB
}

' ─── Connessioni cross-tier ──────────────────────────────────
pHttpOut  --> IHTTP
IHTTP     --> pHttpIn

pDataOut1 --> IProfile
pDataOut2 --> IProfile
IProfile  --> pDataIn

@enduml