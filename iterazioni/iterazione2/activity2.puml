@startuml
title Activity Diagram - Iterazione 2

|Utente|
start
:Inserisce domanda + JWT;

|API Gateway|
:Riceve richiesta + JWT;
:Valida token JWT;

if (Token JWT valido?) then (Sì)
  |MongoDB|
  :Cerca profilo utente\nper userId nel JWT;
  :Restituisce profilo;

  |API Gateway|
  :Inietta profilo nel prompt;
else (No)
  |API Gateway|
  :Accesso senza profilo\n(risposta generica);
endif

|Orchestrator Agent|
:Riceve richiesta;
:Invia richiesta al Classifier;

|Classifier Agent|
:Classifica intento;
:Restituisce categoria;

|Orchestrator Agent|
:Invia richiesta + profilo al Generator;

|Generator Agent|
:Genera risposta preliminare;
:Restituisce bozza;

|Orchestrator Agent|
:Invia bozza al Revision;

|Revision Agent|
:Revisiona risposta;
:Restituisce risposta finale;

|Orchestrator Agent|
:Invia risposta all'API Gateway;

|API Gateway|
:Invia risposta all'utente;

|Utente|
:Visualizza risposta;
stop

@enduml