@startuml AgenticUniBG_ComponentDiagram
title Component Diagram - Iterazione 0

skinparam componentStyle rectangle
skinparam defaultFontName Arial
skinparam backgroundColor #FFFFFF
skinparam component {
  BackgroundColor #FFFFFF
  BorderColor #000000
  FontColor #000000
}
skinparam interface {
  BackgroundColor #FFFFFF
  BorderColor #000000
  FontColor #000000
}
skinparam package {
  BackgroundColor #F0F0F0
  BorderColor #000000
  FontColor #000000
}
skinparam database {
  BackgroundColor #FFFFFF
  BorderColor #000000
  FontColor #000000
}
skinparam cloud {
  BackgroundColor #FFFFFF
  BorderColor #000000
  FontColor #000000
}
skinparam arrow {
  Color #000000
}

' ─────────────────────────────────────────
' FRONTEND
' ─────────────────────────────────────────
package "Frontend" {
  [React Native App] as APP
}

' ─────────────────────────────────────────
' BACKEND (LangChain)
' ─────────────────────────────────────────
package "Backend (LangChain)" {

  [API Gateway] as GW

  interface "REST /api/v1" as IREST
  interface "WebSocket /ws" as IWS
  interface "IOrchestrate" as IORCH

  [Orchestrator Agent] as ORCH

  [Classifier Agent] as CLA
  [Profile Agent]    as PRO
  [Memory Agent]     as MEM
  [Web Agent]        as WEB
  [Documents Agent]  as DOC
  [Generator Agent]  as GEN
  [Revision Agent]   as REV
  [Feedback Agent]   as FBK

  interface "IClassify"  as ICLA
  interface "IProfile"   as IPRO
  interface "IMemory"    as IMEM
  interface "IWebSearch" as IWEB
  interface "IDocSearch" as IDOC
  interface "IGenerate"  as IGEN
  interface "IRevise"    as IREV
  interface "IFeedback"  as IFBK

  package "Persistence" {
    database "Student Profile DB\n(SQL)" as SPDB
    database "Q&A History DB\n(NoSQL)"   as QADB
  }

  interface "IStudentProfile" as ISPDB
  interface "IQAHistory"      as IQADB
}

' ─────────────────────────────────────────
' EXTERNAL
' ─────────────────────────────────────────
cloud "Web / Internet" as WEBEXT

[LLM Provider\n(Ollama)] as LLM

interface "LLM API" as ILLM

' ─────────────────────────────────────────
' RELAZIONI
' ─────────────────────────────────────────

' Frontend -> Gateway
APP --> IREST
IREST --> GW

APP --> IWS
IWS --> GW

' Gateway -> Orchestrator
GW --> IORCH
IORCH --> ORCH

' Orchestrator -> Agents
ORCH --> ICLA
ICLA --> CLA

ORCH --> IPRO
IPRO --> PRO

ORCH --> IMEM
IMEM --> MEM

ORCH --> IWEB
IWEB --> WEB

ORCH --> IDOC
IDOC --> DOC

ORCH --> IGEN
IGEN --> GEN

ORCH --> IREV
IREV --> REV

ORCH --> IFBK
IFBK --> FBK

' Profile Agent -> Student Profile DB
PRO --> ISPDB
ISPDB --> SPDB

' Memory Agent -> Q&A History DB
MEM --> IQADB
IQADB --> QADB

' Web Agent -> Internet
WEB --> WEBEXT

' Generator / Revision -> LLM
GEN --> ILLM
REV --> ILLM
ILLM --> LLM

@enduml