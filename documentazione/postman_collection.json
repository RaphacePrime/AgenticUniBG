{
  "info": {
    "name": "AgenticUniBG - Test API",
    "description": "Collezione completa di test API per tutte le iterazioni del progetto AgenticUniBG.\n\nPer eseguire i test:\n1. Avviare il backend con `docker-compose up`\n2. Importare questa collezione in Postman\n3. Impostare la variabile `base_url` (default: http://localhost:8000)\n4. Eseguire i test nell'ordine indicato",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000"
    },
    {
      "key": "test_matricola",
      "value": "1087210"
    },
    {
      "key": "test_password",
      "value": "test2026"
    }
  ],
  "item": [
    {
      "name": "Iterazione 1 - Query e Risposte",
      "description": "Test del flusso base: inviare domanda e ricevere risposta dalla pipeline di agenti.",
      "item": [
        {
          "name": "IT1-01 Health Check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/health",
            "description": "Verifica che il backend sia raggiungibile e operativo."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Service healthy', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.status).to.eql('healthy');",
                  "    pm.expect(json.service).to.eql('agentic-unibg-backend');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "IT1-02 Query Generica (Ospite)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/agent/query",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"Dove si trova la mensa universitaria?\",\n  \"user_info\": {\n    \"status\": \"ospite\"\n  }\n}"
            },
            "description": "Invia una domanda generica come utente ospite. Verifica che la pipeline restituisca una risposta valida."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response contains answer', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.response).to.be.a('string');",
                  "    pm.expect(json.response.length).to.be.greaterThan(10);",
                  "});",
                  "pm.test('Agent used is orchestrator', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.agent_used).to.eql('orchestrator');",
                  "});",
                  "pm.test('Metadata contains workflow steps', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.metadata).to.have.property('workflow_steps');",
                  "    pm.expect(json.metadata.workflow_steps).to.be.an('array');",
                  "    pm.expect(json.metadata.workflow_steps.length).to.be.greaterThan(0);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "IT1-03 Query Informazioni Corso",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/agent/query",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"Chi è il docente del corso di Progettazione Algoritmi e Compelessità?\",\n  \"user_info\": {\n    \"status\": \"ospite\"\n  }\n}"
            },
            "description": "Verifica la classificazione in categoria 'informazioni_corso'."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response not empty', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.response.length).to.be.greaterThan(10);",
                  "});",
                  "pm.test('Category is informazioni_corso or generale', function () {",
                  "    var json = pm.response.json();",
                  "    var validCategories = ['informazioni_corso', 'generale'];",
                  "    pm.expect(validCategories).to.include(json.metadata.workflow_steps[0].result.category);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "IT1-04 Query Vuota (Errore)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/agent/query",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"\"\n}"
            },
            "description": "Verifica la gestione di una query vuota."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns response or error', function () {",
                  "    var code = pm.response.code;",
                  "    pm.expect([200, 422, 500]).to.include(code);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Iterazione 2 - Auth e Personalizzazione",
      "description": "Test di registrazione, login, gestione profilo e personalizzazione risposte.",
      "item": [
        {
          "name": "IT2-01 Registrazione Nuovo Studente",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/register",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test\",\n  \"surname\": \"User\",\n  \"matricola\": \"{{test_matricola}}\",\n  \"password\": \"{{test_password}}\",\n  \"department\": \"Scuola di Ingegneria\",\n  \"course\": \"Ingegneria informatica\",\n  \"tipology\": \"Magistrale\",\n  \"year\": 2\n}"
            },
            "description": "Registra un nuovo studente e verifica che il cookie JWT venga impostato."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Returns student profile', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.status).to.eql('loggato');",
                  "    pm.expect(json.name).to.eql('Test');",
                  "    pm.expect(json.surname).to.eql('User');",
                  "    pm.expect(json.matricola).to.eql(pm.variables.get('test_matricola'));",
                  "    pm.expect(json.department).to.eql('Scuola di Ingegneria');",
                  "    pm.expect(json.course).to.eql('Ingegneria informatica');",
                  "});",
                  "pm.test('JWT cookie is set', function () {",
                  "    var cookie = pm.response.headers.get('Set-Cookie');",
                  "    pm.expect(cookie).to.include('access_token');",
                  "    pm.expect(cookie).to.include('httponly');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "IT2-02 Registrazione Matricola Duplicata (409)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/register",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test\",\n  \"surname\": \"Duplicate\",\n  \"matricola\": \"{{test_matricola}}\",\n  \"password\": \"password123\",\n  \"department\": \"Scuola di Ingegneria\",\n  \"course\": \"Ingegneria informatica\",\n  \"tipology\": \"Triennale\",\n  \"year\": 1\n}"
            },
            "description": "Tenta la registrazione con una matricola già esistente. Deve restituire 409."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 409 Conflict', function () {",
                  "    pm.response.to.have.status(409);",
                  "});",
                  "pm.test('Error message', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.detail).to.include('già registrata');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "IT2-03 Login con Credenziali Corrette",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/login",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"matricola\": \"{{test_matricola}}\",\n  \"password\": \"{{test_password}}\"\n}"
            },
            "description": "Login con credenziali corrette. Verifica cookie JWT e profilo restituito."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Returns loggato status', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.status).to.eql('loggato');",
                  "    pm.expect(json.matricola).to.eql(pm.variables.get('test_matricola'));",
                  "});",
                  "pm.test('JWT cookie set', function () {",
                  "    var cookie = pm.response.headers.get('Set-Cookie');",
                  "    pm.expect(cookie).to.include('access_token');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "IT2-04 Login Matricola Inesistente (401)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/login",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"matricola\": \"0000000\",\n  \"password\": \"wrongpassword\"\n}"
            },
            "description": "Login con matricola inesistente. Deve restituire 401."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', function () {",
                  "    pm.response.to.have.status(401);",
                  "});",
                  "pm.test('Error detail', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.detail).to.include('non trovata');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "IT2-05 Login Password Errata (401)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/login",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"matricola\": \"{{test_matricola}}\",\n  \"password\": \"WrongPassword!\"\n}"
            },
            "description": "Login con password errata. Deve restituire 401."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', function () {",
                  "    pm.response.to.have.status(401);",
                  "});",
                  "pm.test('Error detail', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.detail).to.include('Password errata');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "IT2-06 Verifica Token (Autenticato)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/auth/verify",
            "description": "Verifica il token JWT dal cookie. Richiede aver eseguito prima il login (IT2-03)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Returns user info', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.status).to.eql('loggato');",
                  "    pm.expect(json.name).to.be.a('string');",
                  "    pm.expect(json.matricola).to.eql(pm.variables.get('test_matricola'));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "IT2-07 Verifica Token Senza Cookie (401)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/auth/verify",
            "header": [
              { "key": "Cookie", "value": "" }
            ],
            "description": "Verifica che senza cookie JWT valido si riceva 401."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', function () {",
                  "    pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "IT2-08 Aggiornamento Profilo",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/auth/profile",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"year\": 1,\n  \"course\": \"Ingegneria meccanica\"\n}"
            },
            "description": "Aggiorna il profilo utente (cambio corso e anno). Richiede autenticazione."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Profile updated', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.year).to.eql(1);",
                  "    pm.expect(json.course).to.eql('Ingegneria meccanica');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "IT2-09 Cambio Password",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/auth/password",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_password\": \"{{test_password}}\",\n  \"new_password\": \"NewPassword456!\"\n}"
            },
            "description": "Cambio password con password corrente valida."
          },
          "event": [
            {
              "listen": "test",
