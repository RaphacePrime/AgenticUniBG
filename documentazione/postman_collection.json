    {
      "name": "Iterazione 3 - Memoria Conversazionale",
      "description": "Test della memoria conversazionale: follow-up, contesto multi-turno.",
      "item": [
        {
          "name": "IT3-01 Prima Domanda (senza storico)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/agent/query",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"Quali sono i corsi della Scuola di Ingegneria?\",\n  \"user_info\": {\n    \"status\": \"ospite\"\n  },\n  \"conversation_history\": []\n}"
            },
            "description": "Prima domanda senza storico conversazionale."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response about engineering courses', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.response.length).to.be.greaterThan(20);",
                  "});",
                  "// Save response for next test",
                  "pm.collectionVariables.set('it3_first_response', pm.response.json().response);"
                ]
              }
            }
          ]
        },
        {
          "name": "IT3-02 Follow-up con Contesto",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/agent/query",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"E quelli di informatica nello specifico?\",\n  \"user_info\": {\n    \"status\": \"ospite\"\n  },\n  \"conversation_history\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Quali sono i corsi della Scuola di Ingegneria?\"\n    },\n    {\n      \"role\": \"assistant\",\n      \"content\": \"La Scuola di Ingegneria offre diversi corsi...\"\n    }\n  ]\n}"
            },
            "description": "Domanda di follow-up che richiede contesto dalla conversazione precedente. Il sistema deve capire che 'quelli di informatica' si riferisce ai corsi di Ingegneria."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response uses conversation context', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.response.length).to.be.greaterThan(20);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "IT3-03 Multi-turno con Cambio Argomento",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/agent/query",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"Invece dove si trova la mensa?\",\n  \"user_info\": {\n    \"status\": \"ospite\"\n  },\n  \"conversation_history\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Quali sono i corsi della Scuola di Ingegneria?\"\n    },\n    {\n      \"role\": \"assistant\",\n      \"content\": \"La Scuola di Ingegneria offre corsi di laurea triennale e magistrale in...\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"E quelli di informatica nello specifico?\"\n    },\n    {\n      \"role\": \"assistant\",\n      \"content\": \"I corsi di Ingegneria informatica disponibili sono...\"\n    }\n  ]\n}"
            },
            "description": "Verifica che il sistema gestisca correttamente un cambio di argomento (da corsi a mensa) mantenendo lo storico."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response about mensa (topic switch)', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.response.length).to.be.greaterThan(10);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "IT3-04 Cronologia Conversazione",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/conversation/history?limit=5",
            "description": "Verifica l'endpoint della cronologia conversazione (ora gestita client-side)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Returns history array', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.history).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "IT3-05 Cancellazione Cronologia",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/conversation/history",
            "description": "Cancella la cronologia delle conversazioni lato server."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('History cleared', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.status).to.eql('success');",
                  "});"
                ]
              }
            }
          ]
        }
