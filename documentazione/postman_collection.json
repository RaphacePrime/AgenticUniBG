            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_password\": \"WrongCurrent!\",\n  \"new_password\": \"whatever\"\n}"
            },
            "description": "Tentativo di cambio password con password corrente errata."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', function () {",
                  "    pm.response.to.have.status(401);",
                  "});",
                  "pm.test('Error message', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.detail).to.include('corrente errata');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "IT2-11 Query Personalizzata (Studente Autenticato)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/agent/query",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"Che materie ho al secondo anno?\",\n  \"user_info\": {\n    \"status\": \"loggato\",\n    \"name\": \"Test\",\n    \"surname\": \"User\",\n    \"matricola\": \"9999999\",\n    \"department\": \"Scuola di Ingegneria\",\n    \"course\": \"Ingegneria informatica\",\n    \"tipology\": \"Magistrale\",\n    \"year\": 2\n  }\n}"
            },
            "description": "Verifica che la risposta sia personalizzata con info del profilo (Ingegneria informatica, Magistrale)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
